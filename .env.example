# Copy this file to .env and fill in values if you want to authenticate via
# a portable token or API key instead of the browser-login volume. Entirely
# optional — if you're using `docker compose run login`, you don't need a
# .env file at all.

# Long-lived token from `claude setup-token` (or: docker compose run login-token).
# Alternative to a browser-session credential stored in the volume.
CLAUDE_CODE_OAUTH_TOKEN=

# Alternative: direct Anthropic API key auth. Note the usage panel shows
# cost estimates rather than plan-percentage bars for API-key accounts.
ANTHROPIC_API_KEY=

# Rarely needed — these already default correctly inside the image.
# CLAUDE_CONFIG_DIR=/data
# CLAUDE_USAGE_WORKDIR=/home/node/workspace
